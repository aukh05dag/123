            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const preview = document.getElementById('imagePreview');
                    preview.src = e.target.result;
                    preview.style.display = 'block';
                };
                reader.readAsDataURL(input.files[0]);
            }
        }

        // ===== МОДЕЛЬ ПРОДУКТА =====
        function openProductModal(id) {
            const product = products.find(p => p.id === id);
            если (!product) return;

            document.getElementById('modalTitle').textContent = product.name;

            const categoryIcons = {
                'с‚РєР°РЅСЊ': 'рџ§µ',
                'СѓСЂРЅРёС‚СѓСЂР°': 'рџ”©',
                'РјРµС…Р°РЅР·Рј': 'вљ™пёЏ',
                'РЅРѕР¶РєРё': 'рџ¦¶',
                'РґСЂСѓРіРѕРµ': 'рџ“¦'
            };

            document.getElementById('modalBody').innerHTML = `
                ${product.image ? `<img src="${product.image}" style="width:100%; border-radius:12px; margin-bottom:15px;" alt="${product.name}">` : `<div style="text-align:center; font-size:5rem; margin-bottom:15px;">${categoryIcons[product.category] || 'рџ“¦'}</div>`}
                <p style="color: var(--text-light);margin-bottom:10px;">Отображение: <strong>${product.category</strong></p>
                <p style="margin-bottom:15px; line-height:1.7;">${product.description || 'РћРїРёСЃР°РЅРёРѕС‚СЃСѓС‚СЃС‚РІСѓРµС‚.'</p>
                <div style="background: var(--olive-bg); padding:15px; border-radius:12px; text-align:center; margin-bottom:20px;">
                    <span style="font-size:1.8rem; font-weight:800; color: var(--olive-main);">${product.price.toLocaleString('ru-RU')} в‚Ѕ</span>
                </div>
                <button class="btn btn-olive" style="width:100%; justify-content:center; padding:12px;" onclick="closeModal(); document.getElementById('contact').scrollIntoView({behavior:'smooth'})">
                    ‰пёЏ РЎРІСЏР·Р°С‚СЊСЃСЏ РїРѕ СЌС‚РѕРјСѓ С‚РѕРІР°СЂСѓ
                </button>
            `;

            document.getElementById('productModal').classList.add('active');
        }

        function closeModal() {
            document.getElementById('productModal').classList.remove('active');
        }

        // ===== СООБЩЕНИЯ =====
        function sendMessage(e) {
            e.preventDefault();

            const msg = {
                id: Date.now(),
                имя: document.getElementById('msgName').value.trim(),
                контакт: document.getElementById('msgContact').value.trim(),
                текст: document.getElementById('msgText').value.trim(),
                дата: new Date().toLocaleString('ru-RU')
            };

            messages.push(msg);
            localStorage.setItem('mebel_messages', JSON.stringify(messages));

            e.target.reset();
            showNotification('Сделано все правильно!', 'success');
            renderMessages();
        }

        function renderMessages() {
            const container = document.getElementById('messagesList');

            if (messages.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <div class="icon">рџ“</div>
                        <p>Создание сайта</p>
                    </div>
                `;
                возвращаться;
            }

            container.innerHTML = messages.slice().reverse().map(m => `
                <div class="message-card">
                    <div class="msg-header">
                        <span class="msg-name">рџ'¤ ${m.name} | ${m.contact}</span>
                        <span class="msg-date">${m.date}</span>
                    </div>
                    <p class="msg-text">${m.text}</p>
                    <button class="btn btn-danger btn-small" style="margin-top:10px;" onclick="deleteMessage(${m.id})">рџ—'пёЏ РЈРґР°Р»РёС‚СЊ</button>
                </div>
            `).join('');
        }

        функция deleteMessage(id) {
            messages = messages.filter(m => m.id !== id);
            localStorage.setItem('mebel_messages', JSON.stringify(messages));
            renderMessages();
            showNotification('Нет информации', 'ошибка');
        }

        // ===== АДМИНИСТРАТОР =====
        function openAdmin() {
            document.getElementById('adminPanel').classList.add('active');
            renderAdminProducts();
            renderMessages();
        }

        function closeAdmin() {
            document.getElementById('adminPanel').classList.remove('active');
            editingId = null;
        }

        function switchTab(tab, btn) {
            document.querySelectorAll('.admin-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById('tab-' + tab).classList.add('active');
        }

        function renderAdminProducts() {
            const container = document.getElementById('adminProductsList');

            if (products.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <div class="icon">рџ“¦</div>
                        <p>РўРѕРІР°СЂРѕРІ РїРѕРєР° РЅРµС‚. Р”Р°РІСЊС‚Рµ РїРµСЂРІС‹Р№!</p>
                    </div>
                `;
                возвращаться;
            }

            container.innerHTML = products.map(p => `
                <div class="admin-product-item">
                    ${p.image
                        ? `<img src="${p.image}" alt="${p.name}">`
                        : `<div style="width:60px;height:60px;background:var(--olive-bg);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;">рџ“¦</div>`
                    }
                    <div class="info">
                        <h4>${p.name}</h4>
                        <p>${p.price.toLocaleString('ru-RU')} ‚Ѕ | ${p.category}</p>
                    </div>
                    <div class="actions">
                        <button class="btn btn-olive btn-small" onclick="editProduct(${p.id})">вњЏпёЏ</button>
                        <button class="btn btn-danger btn-small" onclick="deleteProduct(${p.id})">рџ—'пёЏ</button>
                    </div>
                </div>
            `).join('');
        }

        // ===== УВЕДОМЛЕНИЯ =====
        function showNotification(text, type = 'success') {
            const notif = document.getElementById('notification');
            notif.textContent = text;
            notif.className = 'notification ' + type + ' show';

            setTimeout(() => {
                notif.classList.remove('show');
            }, 3000);
        }

        // Закрытие модальных окон при щелчке по наложенному изображению
        document.getElementById('adminPanel').addEventListener('click', function(e) {
            if (e.target === this) closeAdmin();
        });

        document.getElementById('productModal').addEventListener('click', function(e) {
            if (e.target === this) closeModal();
        });
    </script>
</body>
</html>
